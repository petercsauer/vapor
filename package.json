{
  "name": "vapor",
  "productName": "Vapor",
  "version": "0.2.0",
  "description": "A frosted-glass terminal emulator",
  "main": ".webpack/main",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "NODE_ENV=production electron-forge package",
    "make": "NODE_ENV=production electron-forge make",
    "make:arm64": "NODE_ENV=production electron-forge make --arch=arm64",
    "make:x64": "NODE_ENV=production electron-forge make --arch=x64",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "postinstall": "electron-rebuild -f -o node-pty",
    "version:bump": "npm version patch --no-git-tag-version"
  },
  "keywords": [],
  "author": {
    "name": "Peter Sauer",
    "email": "petercsauer@me.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/petercsauer/vapor.git"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-webpack": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^16.11.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.5",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vercel/webpack-asset-relocator-loader": "^1.7.3",
    "@vitest/coverage-v8": "^4.1.2",
    "css-loader": "^6.11.0",
    "electron": "^41.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "fork-ts-checker-webpack-plugin": "^7.3.0",
    "jsdom": "^27.0.1",
    "monaco-editor-webpack-plugin": "^7.1.1",
    "node-loader": "^2.1.0",
    "postcss": "^8.5.8",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.4",
    "typescript": "~4.5.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "electron-log": "^5.4.3",
    "lucide-react": "^1.7.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-mosaic-component": "^6.1.1",
    "ssh2": "^1.17.0",
    "update-electron-app": "^3.1.2",
    "zustand": "^5.0.12"
  }
}
